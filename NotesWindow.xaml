<Window x:Class="Zimbar.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="ZimNotes"
        Icon="assets/ZimNotes.png"
        Width="980" Height="640"
        MinWidth="760" MinHeight="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True" ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality">

    <Grid Margin="18">
        <Border Style="{StaticResource Zimbar.Border.CosmicCard}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="34" ShadowDepth="0" Opacity="0.42" Color="#42F3C8"/>
            </Border.Effect>

            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,14" MouseLeftButtonDown="Header_MouseDown">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Style="{StaticResource Chip}" Click="New_Click" Content="+ nota" Padding="13,6"/>
                        <Button Style="{StaticResource Chip}" Click="CloseWin_Click" Content="×" Margin="0" Padding="11,6"/>
                    </StackPanel>
                    <DockPanel>
                        <Border Width="30" Height="30" CornerRadius="10"
                                Background="{DynamicResource SurfaceHi}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,10,0">
                            <TextBlock Text="Z" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Accent}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="ZimNotes" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMain}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock x:Name="CountText" Text="" FontSize="11.5"
                                           Foreground="{DynamicResource TextDim}"/>
                                <TextBlock x:Name="StatusText" Text="" FontSize="11.5"
                                           Foreground="{DynamicResource AccentSoft}"
                                           Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </DockPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="292"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource Surface}"
                            BorderBrush="#22FFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="2,0,2,10">
                                <TextBlock Text="BIBLIOTECA"
                                           FontSize="10"
                                           FontFamily="{DynamicResource Mono}"
                                           Foreground="{DynamicResource TextDim}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <TextBox x:Name="SearchBox"
                                     Grid.Row="1"
                                     Style="{StaticResource InlineAdd}"
                                     TextChanged="SearchBox_TextChanged"
                                     FontSize="12.5"
                                     Margin="0,0,0,12"
                                     ToolTip="buscar notas"/>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="NotesListPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{DynamicResource Surface}"
                            BorderBrush="#1FFFFFFF"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox x:Name="EdTitle"
                                     Grid.Row="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextMain}"
                                     CaretBrush="{DynamicResource Accent}"
                                     FontSize="24"
                                     FontWeight="SemiBold"
                                     FontFamily="{DynamicResource Display}"
                                     Padding="0,0,0,9"
                                     TextChanged="EditorTextChanged"/>

                            <Border Grid.Row="1" Height="1" Margin="0,0,0,14" Opacity="0.22"
                                    Background="{DynamicResource CardBorderBrush}"/>

                            <TextBox x:Name="EdBody"
                                     Grid.Row="2"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextMain}"
                                     CaretBrush="{DynamicResource Accent}"
                                     FontSize="15"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="EditorTextChanged"/>

                            <DockPanel Grid.Row="3" Margin="0,14,0,0">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource Chip}" Click="EditorDelete_Click" x:Name="EdDelete" Content="excluir" Padding="12,6"/>
                                    <Button Style="{StaticResource PrimaryBtn}" Click="EditorSave_Click" Content="salvar" Margin="0" Padding="14,6"/>
                                </StackPanel>
                                <StackPanel x:Name="ColorRow" Orientation="Horizontal" VerticalAlignment="Center"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <primitives:Thumb x:Name="ResizeThumb"
                          Width="26" Height="26"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,6,6"
                          Cursor="SizeNWSE"
                          DragDelta="ResizeThumb_DragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Grid Opacity="0.62">
                        <Border Width="24" Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                        <Rectangle Width="12" Height="2" RadiusX="1" RadiusY="1"
                                   Fill="{DynamicResource AccentSoft}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,2,7"
                                   RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="-45"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                        <Rectangle Width="8" Height="2" RadiusX="1" RadiusY="1"
                                   Fill="{DynamicResource AccentSoft}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,2,3"
                                   RenderTransformOrigin="0.5,0.5">
                            <Rectangle.RenderTransform>
                                <RotateTransform Angle="-45"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Grid>
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
