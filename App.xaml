<Application x:Class="Zimbar.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <!-- Fontes do Acervo (embutidas): Archivo Black display + Space Grotesk corpo.
             Mono aponta pra Space Grotesk tb (Acervo não usa mono; labels são grotesk bold). -->
        <FontFamily x:Key="Body">pack://application:,,,/assets/fonts/#Space Grotesk, Segoe UI</FontFamily>
        <FontFamily x:Key="Display">pack://application:,,,/assets/fonts/#Archivo Black, Segoe UI</FontFamily>
        <FontFamily x:Key="Mono">pack://application:,,,/assets/fonts/#Space Grotesk, Segoe UI</FontFamily>

        <!-- Valores iniciais (paleta Acervo); o ThemeManager troca em runtime -->
        <SolidColorBrush x:Key="Accent" Color="#7b61ff"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#d9d1ff"/>
        <SolidColorBrush x:Key="Ink" Color="#161613"/>
        <SolidColorBrush x:Key="TextInk" Color="#161613"/>
        <SolidColorBrush x:Key="TextMain" Color="#161613"/>
        <SolidColorBrush x:Key="TextDim" Color="#6f6a5c"/>
        <SolidColorBrush x:Key="TextDone" Color="#a39b85"/>
        <SolidColorBrush x:Key="Surface" Color="#fffdf7"/>
        <SolidColorBrush x:Key="SurfaceHi" Color="#fffdf7"/>
        <SolidColorBrush x:Key="ChipBg" Color="#fffdf7"/>
        <SolidColorBrush x:Key="ChipBgHover" Color="#e8e1cf"/>
        <SolidColorBrush x:Key="Mist" Color="#e8e1cf"/>
        <SolidColorBrush x:Key="Cream" Color="#f6f2e7"/>
        <SolidColorBrush x:Key="CardBg" Color="#f6f2e7"/>
        <SolidColorBrush x:Key="Sun" Color="#ffc940"/>
        <SolidColorBrush x:Key="SunSoft" Color="#ffe9ac"/>
        <SolidColorBrush x:Key="Tang" Color="#ff5f35"/>
        <SolidColorBrush x:Key="TangSoft" Color="#ffd3c4"/>
        <SolidColorBrush x:Key="Leaf" Color="#3ec46d"/>
        <SolidColorBrush x:Key="LeafSoft" Color="#c4eed4"/>
        <SolidColorBrush x:Key="Sky" Color="#4d7cff"/>
        <SolidColorBrush x:Key="SkySoft" Color="#cdd9ff"/>
        <SolidColorBrush x:Key="Grape" Color="#7b61ff"/>
        <SolidColorBrush x:Key="GrapeSoft" Color="#d9d1ff"/>
        <SolidColorBrush x:Key="Rose" Color="#ff5c8a"/>
        <SolidColorBrush x:Key="RoseSoft" Color="#ffd0de"/>
        <SolidColorBrush x:Key="BlockYellow" Color="#ffc940"/>
        <SolidColorBrush x:Key="BlockLime" Color="#3ec46d"/>
        <SolidColorBrush x:Key="BlockPink" Color="#ff5c8a"/>
        <SolidColorBrush x:Key="BlockPurple" Color="#7b61ff"/>
        <SolidColorBrush x:Key="BlockBlue" Color="#4d7cff"/>
        <SolidColorBrush x:Key="BlockCoral" Color="#ff5f35"/>
        <SolidColorBrush x:Key="Dificil" Color="#ff5f35"/>
        <SolidColorBrush x:Key="DificilBg" Color="#ffd3c4"/>
        <SolidColorBrush x:Key="Media" Color="#ffc940"/>
        <SolidColorBrush x:Key="MediaBg" Color="#ffe9ac"/>
        <SolidColorBrush x:Key="Facil" Color="#3ec46d"/>
        <SolidColorBrush x:Key="FacilBg" Color="#c4eed4"/>
        <RotateTransform x:Key="RotateRailText" Angle="-90"/>

        <!-- Design System aliases: novos componentes devem preferir Zimbar.*.
             As chaves curtas continuam por compatibilidade com telas existentes. -->
        <FontFamily x:Key="Zimbar.Font.Body">Segoe UI Variable Text, Segoe UI</FontFamily>
        <FontFamily x:Key="Zimbar.Font.Display">Segoe UI Variable Display Semilight, Segoe UI Semilight, Segoe UI</FontFamily>
        <FontFamily x:Key="Zimbar.Font.Mono">Cascadia Mono, Cascadia Code, Consolas, Segoe UI</FontFamily>
        <SolidColorBrush x:Key="Zimbar.Brush.Accent" Color="#C9A6FF"/>
        <SolidColorBrush x:Key="Zimbar.Brush.AccentSoft" Color="#9A7FE8"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Text.OnAccent" Color="#120A22"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Text.Primary" Color="#F1ECFF"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Text.Secondary" Color="#B4ADD4"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Text.Muted" Color="#7F78A2"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Surface.Glass" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Surface.GlassStrong" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="Zimbar.Brush.Surface.CardFlat" Color="#1E1636"/>
        <Color x:Key="Zimbar.Color.Accent">#C9A6FF</Color>
        <Color x:Key="Zimbar.Color.Glow">#8B5CFF</Color>

        <!-- ══ Chip (DESIGN.md §5): bloco branco, borda de tinta 2px, hover pinta de accent ══ -->
        <Style x:Key="Chip" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ChipBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="11,5"/>
            <Setter Property="Margin" Value="0,0,7,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{DynamicResource Body}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Ink}" BorderThickness="2"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ChipBgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Botão primário (DESIGN.md §5): borda DUPLA = sombra dura crua; press AFUNDA ══ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Accent}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextInk}"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{DynamicResource Display}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="sh" Background="{DynamicResource Ink}"
                                    CornerRadius="11" Margin="3,3,0,0"/>
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource Ink}" BorderThickness="2"
                                    CornerRadius="11"
                                    Padding="{TemplateBinding Padding}"
                                    Margin="0,0,3,3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoft}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Margin" Value="3,3,0,0"/>
                                <Setter TargetName="sh" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NeoBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}"/>
        <Style x:Key="Zimbar.Button.Primary" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}"/>

        <!-- ══ Tab de navegação (DESIGN.md §5): repouso tinta; hover bloco branco;
             ativa = bloco de TINTA com texto claro (via código no SwitchView) ══ -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{DynamicResource Body}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="2"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Mist}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Zimbar.Button.Chip" TargetType="Button" BasedOn="{StaticResource Chip}"/>
        <Style x:Key="Zimbar.Button.Nav" TargetType="Button" BasedOn="{StaticResource NavBtn}"/>

        <!-- ══ Linha de lista clicável ══ -->
        <Style x:Key="GhostItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontFamily" Value="{DynamicResource Body}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#12161613"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Zimbar.Button.Ghost" TargetType="Button" BasedOn="{StaticResource GhostItem}"/>

        <!-- ══ Campo de texto discreto (vidro + hairline accent) ══ -->
        <Style x:Key="InlineAdd" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMain}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontFamily" Value="{DynamicResource Body}"/>
            <Setter Property="Padding" Value="11,7"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                BorderBrush="{DynamicResource Ink}" BorderThickness="2">
                            <!-- sem VerticalAlignment=Center: centralizado a caixa fica do tamanho
                                 exato da linha e come o topo das letras (ex.: "BRe") -->
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Zimbar.TextBox.InlineAdd" TargetType="TextBox" BasedOn="{StaticResource InlineAdd}"/>

        <!-- ══ Só o X: sem bolinha, sem moldura — apagar item de lista ══ -->
        <Style x:Key="IconX" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDone}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="cp" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Opacity="0.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cp" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource Tang}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Scrollbar fina e luminosa ══ -->
        <Style x:Key="NeoScroll" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="th" CornerRadius="4" Margin="2,2"
                                                        Background="#40161613"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="th" Property="Background" Value="{DynamicResource Ink}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource NeoScroll}"/>
        <Style x:Key="Zimbar.ScrollBar.Neo" TargetType="ScrollBar" BasedOn="{StaticResource NeoScroll}"/>

        <Style x:Key="Zimbar.Border.GlassPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Ink}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15,12"/>
        </Style>
        <!-- Card principal neobrutal: papel chapado, borda de tinta grossa, sombra dura -->
        <Style x:Key="Zimbar.Border.CosmicCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect" Value="{DynamicResource CardGlow}"/>
        </Style>
        <Style x:Key="Zimbar.Border.PopupCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Ink}"/>
            <Setter Property="BorderThickness" Value="2.5"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

    </Application.Resources>
</Application>
